# Blumira API Credentials
# Get these from your Blumira account: Settings > API Management
BLUMIRA_CLIENT_ID=your_client_id_here
BLUMIRA_CLIENT_SECRET=your_client_secret_here

# Demo Mode - set to "true" to use synthetic data without real API credentials
# Useful for testing, demos, and development without a Blumira account
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false
